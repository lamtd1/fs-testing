// Prisma schema — nguồn sự thật (source of truth) cho database.
// Sau khi sửa file này, chạy: pnpm --filter @app/api prisma:migrate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Role cho RBAC. Bắt đầu đơn giản với 2 vai trò; có thể mở rộng.
enum Role {
  USER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String?
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}
