// Prisma schema — nguồn sự thật (source of truth) cho database.
// Sau khi sửa file này, chạy: pnpm --filter @app/api prisma:migrate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Role cho RBAC. Bắt đầu đơn giản với 2 vai trò; có thể mở rộng.
enum Role {
  USER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  // Nullable: user đăng ký qua OAuth (Phần 3) sẽ không có password.
  passwordHash String?
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Một user có thể liên kết nhiều tài khoản OAuth (Google, Keycloak...).
  oauthAccounts OAuthAccount[]

  @@map("users")
}

// Liên kết một danh tính từ provider bên ngoài với một User nội bộ.
// Ví dụ: user "alice" đăng nhập bằng Google -> tạo 1 dòng ở đây trỏ về alice.
model OAuthAccount {
  id                String @id @default(cuid())
  provider          String // "google" | "keycloak"
  providerAccountId String // "sub" (subject) do provider cấp — id duy nhất bên họ
  userId            String
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // Cùng một (provider, tài khoản bên đó) chỉ được liên kết 1 lần.
  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}
