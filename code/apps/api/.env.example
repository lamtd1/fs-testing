# gateway (apps/api) — copy thành .env:  cp .env.example .env
NODE_ENV=development
PORT=4000
CORS_ORIGIN="http://localhost:5173"
AUTH_SERVICE_URL="http://localhost:4001"
USER_SERVICE_URL="http://localhost:4002"

# (7.3) verify JWT tại gateway — TRÙNG secret auth-service ký
JWT_ACCESS_SECRET="thay-bang-secret-ngau-nhien"
# secret chung để service tin header do gateway gắn
GATEWAY_SECRET="gateway-shared-secret"

# --- Tracing (6.6) --- để trống = dùng default localhost:4318; OTEL_SDK_DISABLED=true để tắt
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
