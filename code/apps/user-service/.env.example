# user-service — copy thành .env trong THƯ MỤC NÀY:  cp .env.example .env
NODE_ENV=development
PORT=4002

# DB RIÊNG của user-service
DATABASE_URL="postgresql://app:app_password@localhost:5432/app_user?schema=public"

CORS_ORIGIN="http://localhost:5173"

# (7.3) tin context do gateway gắn -> chỉ cần secret chung (không verify JWT)
GATEWAY_SECRET="gateway-shared-secret"

# Cổng gRPC nội bộ (6.3)
GRPC_PORT=4092

# --- Tracing (6.6) --- để trống = dùng default localhost:4318; OTEL_SDK_DISABLED=true để tắt
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
