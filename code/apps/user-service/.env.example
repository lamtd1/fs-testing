# user-service — copy thành .env trong THƯ MỤC NÀY:  cp .env.example .env
NODE_ENV=development
PORT=4002

# DB RIÊNG của user-service
DATABASE_URL="postgresql://app:app_password@localhost:5432/app_user?schema=public"

CORS_ORIGIN="http://localhost:5173"

# Phải TRÙNG JWT_ACCESS_SECRET với auth-service để verify được access token
JWT_ACCESS_SECRET="thay-bang-secret-ngau-nhien"

# Cổng gRPC nội bộ (6.3)
GRPC_PORT=4092
