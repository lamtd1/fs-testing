# auth-service — copy thành .env trong THƯ MỤC NÀY:  cp .env.example .env
NODE_ENV=development
PORT=4001

# DB RIÊNG của auth-service
DATABASE_URL="postgresql://app:app_password@localhost:5432/app_auth?schema=public"

REDIS_URL="redis://localhost:6379"

# Dùng chung secret với các service khác để verify được JWT chéo
JWT_ACCESS_SECRET="thay-bang-secret-ngau-nhien"
JWT_REFRESH_SECRET="thay-bang-secret-khac"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"

CORS_ORIGIN="http://localhost:5173"

# Địa chỉ user-service để gọi liên service
USER_SERVICE_URL="http://localhost:4002"
USER_SERVICE_GRPC="localhost:4092"

# --- OAuth / OIDC (6.2b) --- redirect_uri trỏ về GATEWAY (:4000)
FRONTEND_URL="http://localhost:5173"
OAUTH_REDIRECT_BASE="http://localhost:4000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
KEYCLOAK_ISSUER="http://localhost:8081/realms/app"
KEYCLOAK_CLIENT_ID="app-api"
KEYCLOAK_CLIENT_SECRET="keycloak-client-secret"
