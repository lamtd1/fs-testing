# ============================================
#  Copy file này thành .env rồi điền giá trị:
#    cp .env.example .env
#  File .env KHÔNG được commit (đã có trong .gitignore)
# ============================================

# --- App ---
NODE_ENV=development
PORT=4000

# --- PostgreSQL ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL="postgresql://app:app_password@localhost:5432/app_db?schema=public"

# --- Redis (Phần 2: lưu refresh token — rotation + reuse detection) ---
REDIS_URL="redis://localhost:6379"

# --- Auth (Phần 2) ---
# Sinh secret ngẫu nhiên: openssl rand -base64 32
JWT_ACCESS_SECRET="thay-bang-secret-ngau-nhien"
JWT_REFRESH_SECRET="thay-bang-secret-khac"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"

# --- CORS ---
CORS_ORIGIN="http://localhost:5173"
