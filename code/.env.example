# ============================================
#  Copy file này thành .env rồi điền giá trị:
#    cp .env.example .env
#  File .env KHÔNG được commit (đã có trong .gitignore)
# ============================================

# --- App ---
NODE_ENV=development
PORT=4000

# --- PostgreSQL ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL="postgresql://app:app_password@localhost:5432/app_db?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Auth (dùng ở Phần 2) ---
# Sinh secret ngẫu nhiên: openssl rand -base64 32
JWT_ACCESS_SECRET="thay-bang-secret-ngau-nhien"
JWT_REFRESH_SECRET="thay-bang-secret-khac"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"

# --- CORS ---
CORS_ORIGIN="http://localhost:5173"

# --- OAuth / OIDC (Phần 3) ---
FRONTEND_URL="http://localhost:5173"
OAUTH_REDIRECT_BASE="http://localhost:4000"

# Google (tuỳ chọn — lấy ở Google Cloud Console)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Keycloak (chạy bằng docker compose up -d keycloak)
KEYCLOAK_ISSUER="http://localhost:8081/realms/app"
KEYCLOAK_CLIENT_ID="app-api"
KEYCLOAK_CLIENT_SECRET="keycloak-client-secret"
