{
  "name": "fullstack-modern",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo tutorial: end-to-end modern web system",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @app/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @app/api prisma:migrate",
    "db:studio": "pnpm --filter @app/api prisma:studio"
  }
}
